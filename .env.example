# =============================================================================
# .env.example — KeyCompute 环境变量配置模板
#
# 使用方法：
#   cp .env.example .env
#   # 编辑 .env 填入实际值，.env 已被 .gitignore 排除
#
# 警告：
#   - 生产环境中所有 "change-me" 占位符必须替换为真实安全值
#   - KC_CRYPTO_SECRET_KEY 一旦数据库写入数据后不可更改（会导致历史数据无法解密）
#   - JWT_SECRET 更换后所有已签发 Token 立即失效
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL 数据库配置
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=keycompute
POSTGRES_USER=keycompute
# 生产环境使用强密码（建议 32 位以上随机字符串）
# 生成命令：openssl rand -base64 32
POSTGRES_PASSWORD=change-me-strong-password

# 数据库连接池（可选，默认值已足够大多数场景）
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2

# ─────────────────────────────────────────────────────────────────────────────
# Redis 缓存配置
# ─────────────────────────────────────────────────────────────────────────────
# 生成命令：openssl rand -base64 32
REDIS_PASSWORD=change-me-redis-password
REDIS_POOL_SIZE=10

# ─────────────────────────────────────────────────────────────────────────────
# JWT 认证配置
# ─────────────────────────────────────────────────────────────────────────────
# JWT 签名密钥（生产环境必须修改！更换后所有 Token 立即失效）
# 生成命令：openssl rand -base64 64
KC_JWT_SECRET=change-me-jwt-secret-key

# JWT 签发者标识
KC_JWT_ISSUER=keycompute

# Token 有效期（秒）默认 1 小时
KC_JWT_EXPIRY_SECS=3600

# ─────────────────────────────────────────────────────────────────────────────
# 加密配置（API Key 存储加密）
# 警告：数据库有数据后不可更换此密钥！
# ─────────────────────────────────────────────────────────────────────────────
# Base64 编码的 32 字节密钥
# 生成命令：openssl rand -base64 32
KC_CRYPTO_SECRET_KEY=change-me-base64-encoded-32-byte-key

# ─────────────────────────────────────────────────────────────────────────────
# 邮件服务配置（用于邮箱验证、密码重置等）
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change-me-smtp-password
SMTP_FROM_ADDRESS=noreply@example.com
SMTP_FROM_NAME=KeyCompute

# ─────────────────────────────────────────────────────────────────────────────
# 应用配置
# ─────────────────────────────────────────────────────────────────────────────
# 对外访问的基础 URL（用于生成邮件中的跳转链接）
APP_BASE_URL=https://example.com

# 前端 Web 服务对外绑定端口（默认 80）
# 生产环境建议在 Nginx/CDN 层处理 443/TLS，此处用 80
WEB_PORT=80
